# AI provider keys — leave whichever ones you don't use blank.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Default provider: "anthropic" | "openai" | "google". Falls back to the next available.
AI_PRIMARY_PROVIDER=anthropic
AI_FALLBACK_PROVIDER=google

# Models
ANTHROPIC_MODEL=claude-opus-4-7
OPENAI_MODEL=gpt-4o
GEMINI_MODEL=gemini-2.5-flash-lite
# -1 = dynamic (max). Set to a positive int (e.g. 8192) to cap thinking tokens.
GEMINI_THINKING_BUDGET=-1

# Optional sync endpoint (Postgres + REST). Leave blank to use local-only mode.
SYNC_ENDPOINT=
SYNC_API_KEY=
