# AI provider keys — leave whichever ones you don't use blank.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Default provider: "anthropic" or "openai". Falls back to the other if first call fails.
AI_PRIMARY_PROVIDER=anthropic
AI_FALLBACK_PROVIDER=openai

# Models
ANTHROPIC_MODEL=claude-opus-4-7
OPENAI_MODEL=gpt-4o

# Optional sync endpoint (Postgres + REST). Leave blank to use local-only mode.
SYNC_ENDPOINT=
SYNC_API_KEY=
